# ---------------------------------------------------------------------------
# Standalone fork host configuration (build-time)
# ---------------------------------------------------------------------------
# These are read by webpack.config.js at BUILD time and baked into the client
# (the loader, the webpack publicPath, and the SERVER/API_SERVER constants).
# They default to the upstream FrankerFaceZ hosts when unset, so the client
# keeps working during development until your own servers exist.
#
# Set these in your DigitalOcean App Platform component's BUILD_TIME env vars
# (see .do/app.yaml). Topology: split subdomains (cdn.* + api.*).
#
# NOTE: changing these requires a REBUILD — they are not runtime settings.

# Static / code CDN base: client loader, webpack chunks, fonts, CSS, and
# fetched JSON (experiments.json, locale data, emoji data).
FFZ_CDN=https://cdn.example.com

# Data API base: emote sets, badges, room data, auth.
FFZ_API=https://api.example.com

# Staging data sources (Debugging > Data Sources >> Staging). Default to the
# production values above if unset.
FFZ_STAGING_API=https://api.example.com
FFZ_STAGING_CDN=https://cdn.example.com

# Dev-server fallback proxy target for `bun start` (any path not built locally
# is proxied here). Defaults to FFZ_CDN. During the transition you may point
# this at https://cdn2.frankerfacez.com to pull not-yet-self-hosted assets.
# FFZ_DEV_PROXY=https://cdn2.frankerfacez.com
